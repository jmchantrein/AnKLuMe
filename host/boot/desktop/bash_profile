# shellcheck shell=bash
# anklume: terminal-first boot with optional desktop via `startde`
# Parsed parameter: anklume.desktop=<sway|labwc|kde|1>
# Only activates on tty1 with no existing Wayland session

# CLI autocompletion for anklume (Typer-based)
if command -v anklume >/dev/null 2>&1; then
    eval "$(anklume --show-completion bash 2>/dev/null)" || true
fi

# Auto-detect locale from keyboard layout
# Fixes foot "'C' is not a UTF-8 locale" warning
if [ -z "$LANG" ] || [ "$LANG" = "C" ] || [ "$LANG" = "en_US.UTF-8" ]; then
    if grep -q '^KEYMAP=fr' /etc/vconsole.conf 2>/dev/null; then
        export LANG=fr_FR.UTF-8
    fi
fi

# Ensure console keyboard layout is loaded (loadkeys for TTY)
_current_tty="$(tty 2>/dev/null || echo "")"
if [ "${_current_tty#/dev/tty}" != "$_current_tty" ] && command -v loadkeys >/dev/null 2>&1; then
    if grep -q '^KEYMAP=fr' /etc/vconsole.conf 2>/dev/null; then
        loadkeys fr 2>/dev/null || true
    fi
fi
unset _current_tty

if [ "$(tty)" = "/dev/tty1" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    # Setup wizard: run on live ISO if not already configured
    if grep -q 'boot=anklume' /proc/cmdline 2>/dev/null && \
       [ ! -f /run/anklume-start.done ]; then
        echo ""
        echo "  ╔══════════════════════════════════════════════════════════════╗"
        echo "  ║  anklume Setup                                              ║"
        echo "  ╚══════════════════════════════════════════════════════════════╝"
        echo ""
        # Stop the background service (it's blocking on tty2 waiting for input)
        sudo systemctl stop anklume-start.service 2>/dev/null || true
        # Run wizard interactively on this tty
        sudo /opt/anklume/scripts/start.sh
        touch /run/anklume-start.done 2>/dev/null || true
    fi

    # Parse anklume.desktop=<de> from kernel cmdline
    ANKLUME_DE=""
    for param in $(cat /proc/cmdline); do
        case "$param" in
            anklume.desktop=*) ANKLUME_DE="${param#anklume.desktop=}" ;;
        esac
    done
    export ANKLUME_DE

    # Define startde function — launches the desktop environment
    startde() {
        if [ -x /opt/anklume/host/boot/desktop/start-desktop.sh ]; then
            /opt/anklume/host/boot/desktop/start-desktop.sh
        else
            echo "start-desktop.sh not found"
        fi
    }
    export -f startde

    # Splash: show ASCII art + random quote + startde hint
    if [ -n "$ANKLUME_DE" ] && [ -x /opt/anklume/host/boot/desktop/anklume-splash.sh ]; then
        /opt/anklume/host/boot/desktop/anklume-splash.sh
    fi
fi
