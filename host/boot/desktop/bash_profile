# shellcheck shell=bash
# anklume: auto-start KDE Plasma after setup wizard
# Only activates on tty1 with no existing Wayland session

# CLI autocompletion for anklume (Typer-based)
if command -v anklume >/dev/null 2>&1; then
    eval "$(anklume --show-completion bash 2>/dev/null)" || true
fi

# Auto-detect locale from keyboard layout
# Fixes foot "'C' is not a UTF-8 locale" warning
if [ -z "$LANG" ] || [ "$LANG" = "C" ] || [ "$LANG" = "en_US.UTF-8" ]; then
    if grep -q '^KEYMAP=fr' /etc/vconsole.conf 2>/dev/null; then
        export LANG=fr_FR.UTF-8
    fi
fi

# Ensure console keyboard layout is loaded (loadkeys for TTY)
_current_tty="$(tty 2>/dev/null || echo "")"
if [ "${_current_tty#/dev/tty}" != "$_current_tty" ] && command -v loadkeys >/dev/null 2>&1; then
    if grep -q '^KEYMAP=fr' /etc/vconsole.conf 2>/dev/null; then
        loadkeys fr 2>/dev/null || true
    fi
fi
unset _current_tty

if [ "$(tty)" = "/dev/tty1" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    # On live ISO: stop the background service (it blocks tty2 waiting for input)
    if grep -q 'boot=anklume' /proc/cmdline 2>/dev/null; then
        sudo systemctl stop anklume-start.service 2>/dev/null || true
    fi

    # Check if KDE is requested via kernel cmdline (anklume.desktop=kde)
    ANKLUME_DE=""
    for param in $(cat /proc/cmdline); do
        case "$param" in
            anklume.desktop=*) ANKLUME_DE="${param#anklume.desktop=}" ;;
        esac
    done
    export ANKLUME_DE

    # Auto-launch KDE Plasma (no manual startde needed)
    if [ "$ANKLUME_DE" = "kde" ]; then
        # Auto-resume storage pool if previously configured (silent, fast)
        # Skip if LUKS is enabled — needs interactive password
        if [ -f /mnt/anklume-persist/pool.conf ] && \
           ! grep -q 'LUKS_ENABLED=true' /mnt/anklume-persist/pool.conf 2>/dev/null; then
            sudo /opt/anklume/scripts/start.sh --yes >/dev/null 2>&1 &
            disown
        fi
        # Launch open-learn.sh in background (waits for KDE, then opens browser)
        if [ ! -f ~/.anklume/welcome-done ]; then
            /opt/anklume/host/boot/desktop/open-learn.sh &
            disown
        fi
        clear  # Remove console artifacts before KDE starts
        exec /opt/anklume/host/boot/desktop/start-desktop.sh
    fi

    # Console mode (no anklume.desktop= on cmdline): show splash only
    if [ -x /opt/anklume/host/boot/desktop/anklume-splash.sh ]; then
        /opt/anklume/host/boot/desktop/anklume-splash.sh
    fi
fi
