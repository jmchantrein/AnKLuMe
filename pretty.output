Feature: Gate scenarios — critical prerequisites for dependent features # scenarios/_gates.feature:1
  These scenarios run first (underscore sorts before all letters) and
  register gate results used by @requires tags across the test suite.
  If a gate fails here, all @requires.GATE_NAME scenarios are skipped
  automatically instead of failing with confusing import errors.
  @gate.generator
  Scenario: Generator imports and produces files       # scenarios/_gates.feature:10
    Given "python3" is available                       # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                    # scenarios/steps/common_steps.py:19
    And infra.yml from "student-sysadmin"              # scenarios/steps/sync_steps.py:16
    When I run "python3 scripts/generate.py infra.yml" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                # scenarios/steps/common_steps.py:46

  @gate.web_factory
  Scenario: Web factory module imports                                         # scenarios/_gates.feature:20
    Given "python3" is available                                               # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'from scripts.web import create_app; create_app()'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                        # scenarios/steps/common_steps.py:46

  @gate.web_html
  Scenario: HTML helpers module imports                                                                            # scenarios/_gates.feature:26
    Given "python3" is available                                                                                   # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'from scripts.web.html import page_wrap; assert len(page_wrap(chr(84), chr(66))) > 50'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                            # scenarios/steps/common_steps.py:46

  @gate.web_theme
  Scenario: Web theme module imports                                                            # scenarios/_gates.feature:32
    Given "python3" is available                                                                # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'from scripts.web.theme import BASE_CSS; assert len(BASE_CSS) > 50'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                         # scenarios/steps/common_steps.py:46

  @gate.guide_imports
  Scenario: Guide chapters and strings import                                             # scenarios/_gates.feature:40
    Given "python3" is available                                                          # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'import scripts.guide_chapters; import scripts.guide_strings'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                   # scenarios/steps/common_steps.py:46

  @gate.learn_cli
  Scenario: Learn CLI module compiles                       # scenarios/_gates.feature:48
    Given "python3" is available                            # scenarios/steps/common_steps.py:12
    When I run "python3 -m py_compile scripts/cli/learn.py" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                     # scenarios/steps/common_steps.py:46

  @gate.ws_terminal
  Scenario: WebSocket terminal module compiles                    # scenarios/_gates.feature:54
    Given "python3" is available                                  # scenarios/steps/common_steps.py:12
    When I run "python3 -m py_compile scripts/web/ws_terminal.py" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                           # scenarios/steps/common_steps.py:46

  @gate.pty_module
  Scenario: PTY manager module compiles                           # scenarios/_gates.feature:60
    Given "python3" is available                                  # scenarios/steps/common_steps.py:12
    When I run "python3 -m py_compile scripts/web/pty_manager.py" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                           # scenarios/steps/common_steps.py:46

  @gate.content_model
  Scenario: Content model imports and guide loads                                                                                                                   # scenarios/_gates.feature:66
    Given "python3" is available                                                                                                                                    # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'from scripts.web.content import load_guide_sections, load_lab; s = load_guide_sections(); assert len(s) == 1 and len(s[0].pages) == 8'" # scenarios/steps/common_steps.py:34
