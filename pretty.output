Feature: Domain Lifecycle — creation, validation, addressing # scenarios/generated/domain_lifecycle.feature:2

  Scenario: Domain creation generates inventory and group_vars  # scenarios/generated/domain_lifecycle.feature:4
    Given "python3" is available                                # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                             # scenarios/steps/common_steps.py:19
    And infra.yml from "student-sysadmin"                       # scenarios/steps/sync_steps.py:16
    When I run "python3 scripts/generate.py infra.yml"          # scenarios/steps/common_steps.py:34
    Then exit code is 0                                         # scenarios/steps/common_steps.py:46
    And inventory files exist for all domains                   # scenarios/steps/sync_steps.py:89

  Scenario: Enabled false skips generation but reserves IPs                                                                                                                                                                                                                                                                                                                                                                                                      # scenarios/generated/domain_lifecycle.feature:13
    Given "python3" is available                                                                                                                                                                                                                                                                                                                                                                                                                                 # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                                                                                                                                                                                                                                                                                                                                                                                                                              # scenarios/steps/common_steps.py:19
    When I run "python3 -c 'import sys; sys.path.insert(0,"scripts"); from generate import validate; infra={"project_name":"test","global":{"addressing":{"base_octet":10,"zone_base":100}},"domains":{"disabled":{"enabled":False,"trust_level":"semi-trusted","machines":{"disabled-one":{"type":"lxc"}}},"active":{"trust_level":"semi-trusted","machines":{"active-one":{"type":"lxc"}}}}}; errors=validate(infra); assert not errors, errors; print("ok")'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                                                                                                                                                                                                                                                                                          # scenarios/steps/common_steps.py:46
    And output contains "ok"                                                                                                                                                                                                                                                                                                                                                                                                                                     # scenarios/steps/common_steps.py:63

  Scenario: Domain name must be DNS-safe                                                                                                                                                                                                                                                  # scenarios/generated/domain_lifecycle.feature:21
    Given "python3" is available                                                                                                                                                                                                                                                          # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'import re; pattern=re.compile(r"^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"); assert pattern.match("pro"); assert pattern.match("ai-tools"); assert not pattern.match("Pro"); assert not pattern.match("-bad"); assert not pattern.match("bad-"); print("dns-safe ok")'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                                                                                                                   # scenarios/steps/common_steps.py:46
    And output contains "dns-safe ok"                                                                                                                                                                                                                                                     # scenarios/steps/common_steps.py:63

  Scenario: IP addresses are globally unique                           # scenarios/generated/domain_lifecycle.feature:28
    Given "python3" is available                                       # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                                    # scenarios/steps/common_steps.py:19
    And infra.yml with two machines sharing "10.120.1.5"               # scenarios/steps/validation_steps.py:12
    When I run "python3 scripts/generate.py infra.yml" and it may fail # scenarios/steps/common_steps.py:40
    Then exit code is non-zero                                         # scenarios/steps/common_steps.py:55

  Scenario: Trust level must be valid                                  # scenarios/generated/domain_lifecycle.feature:36
    Given "python3" is available                                       # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                                    # scenarios/steps/common_steps.py:19
    And infra.yml with invalid trust_level "super-trusted"             # scenarios/steps/validation_steps.py:205
    When I run "python3 scripts/generate.py infra.yml" and it may fail # scenarios/steps/common_steps.py:40
    Then exit code is non-zero                                         # scenarios/steps/common_steps.py:55

@requires.generator
Feature: Ephemeral Policy and Boot Configuration # scenarios/generated/ephemeral_policy.feature:3

  Scenario: Ephemeral flag validates as boolean                                                                                                                                                                                                                                                                                                                                                                          # scenarios/generated/ephemeral_policy.feature:5
    Given "python3" is available                                                                                                                                                                                                                                                                                                                                                                                         # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                                                                                                                                                                                                                                                                                                                                                                                      # scenarios/steps/common_steps.py:19
    When I run "python3 -c 'import sys; sys.path.insert(0,"scripts"); from generate import validate; infra={"project_name":"t","global":{"addressing":{"base_octet":10,"zone_base":100}},"domains":{"test":{"trust_level":"trusted","ephemeral":"maybe","machines":{"test-a":{"type":"lxc"}}}}}; errors=validate(infra); assert any("ephemeral" in e.lower() for e in errors), "Expected ephemeral error: %s" % errors'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                                                                                                                                                                                                                                                  # scenarios/steps/common_steps.py:46

  Scenario: Boot autostart validates as boolean                                                                                                                                                                                                                                                                                                                                                                                               # scenarios/generated/ephemeral_policy.feature:12
    Given "python3" is available                                                                                                                                                                                                                                                                                                                                                                                                              # scenarios/steps/common_steps.py:12
    And a clean sandbox environment                                                                                                                                                                                                                                                                                                                                                                                                           # scenarios/steps/common_steps.py:19
    When I run "python3 -c 'import sys; sys.path.insert(0,"scripts"); from generate import validate; infra={"project_name":"t","global":{"addressing":{"base_octet":10,"zone_base":100}},"domains":{"test":{"trust_level":"trusted","machines":{"test-a":{"type":"lxc","boot_autostart":"yes"}}}}}; errors=validate(infra); assert any("boot" in e.lower() or "autostart" in e.lower() for e in errors), "Expected boot error: %s" % errors'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                                                                                                                                                                                                                                                                       # scenarios/steps/common_steps.py:46

