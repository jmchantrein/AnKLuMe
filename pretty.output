    When I run "bash scripts/test-nesting.sh --mode invalid 2>&1 || true" # scenarios/steps/common_steps.py:34
    Then output contains "Invalid mode"                                   # scenarios/steps/common_steps.py:63

  Scenario: Nesting test rejects invalid max-depth                        # scenarios/nesting/anklume_nesting.feature:45
    Given "bash" is available                                             # scenarios/steps/common_steps.py:12
    When I run "bash scripts/test-nesting.sh --max-depth 10 2>&1 || true" # scenarios/steps/common_steps.py:34
    Then output contains "Invalid max-depth"                              # scenarios/steps/common_steps.py:63

  Scenario: Nesting context files are individual files not structured config                                                                                                                                                                             # scenarios/nesting/anklume_nesting.feature:51
    Given "python3" is available                                                                                                                                                                                                                         # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'expected = ["absolute_level", "relative_level", "vm_nested", "yolo"]; found = all(f in open("scripts/test-nesting.sh").read() for f in expected); assert found, "Missing nesting context files"; print("context files ok")'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                                                                                  # scenarios/steps/common_steps.py:46
    And output contains "context files ok"                                                                                                                                                                                                               # scenarios/steps/common_steps.py:63

  Scenario: Nesting prefix format is zero-padded 3 digits                                                                                                                                        # scenarios/nesting/anklume_nesting.feature:58
    Given "python3" is available                                                                                                                                                                 # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'fmt = "{level:03d}-"; assert fmt.format(level=0) == "000-"; assert fmt.format(level=1) == "001-"; assert fmt.format(level=12) == "012-"; print("prefix format ok")'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                                                                                          # scenarios/steps/common_steps.py:46
    And output contains "prefix format ok"                                                                                                                                                       # scenarios/steps/common_steps.py:63

  Scenario: Nesting level stop condition                                                                                         # scenarios/nesting/anklume_nesting.feature:65
    Given "python3" is available                                                                                                 # scenarios/steps/common_steps.py:12
    When I run "python3 -c 'level = 2; stop = level >= 2; assert stop, "Should stop at level >= 2"; print("stop condition ok")'" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                                                                          # scenarios/steps/common_steps.py:46
    And output contains "stop condition ok"                                                                                      # scenarios/steps/common_steps.py:63

  Scenario: Nesting test dry-run with --behave flag                         # scenarios/nesting/anklume_nesting.feature:72
    Given "bash" is available                                               # scenarios/steps/common_steps.py:12
    When I run "bash scripts/test-nesting.sh --mode lxc --behave --dry-run" # scenarios/steps/common_steps.py:34
    Then exit code is 0                                                     # scenarios/steps/common_steps.py:46
    And output contains "behave=true"                                       # scenarios/steps/common_steps.py:63
    And output contains "5 passed, 0 failed"                                # scenarios/steps/common_steps.py:63

